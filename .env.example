# Database - PostgreSQL connection string
# Get a free DB from: https://neon.tech or https://railway.app
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/clinicflow?sslmode=require"

# Auth Secret - generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-min-32-chars"

# App URL (your Vercel deployment URL)
NEXTAUTH_URL="https://your-app.vercel.app"
